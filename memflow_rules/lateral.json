{
    "_comment": "Lateral movement & credential theft detection rules for memflow_alerts_lateral. All regex patterns are compiled with re.IGNORECASE at load time.",

    "cred_dump_patterns": [
        "mimikatz",
        "sekurlsa",
        "lsadump",
        "kerberos::list",
        "privilege::debug",
        "Invoke-Mimikatz",
        "SharpKatz",
        "procdump.*lsass",
        "lsass.*procdump",
        "comsvcs\\.dll.*MiniDump",
        "comsvcs.*minidump",
        "Out-Minidump",
        "nanodump",
        "PPLdump",
        "HandleKatz",
        "sharpdump",
        "dump.*credentials?",
        "sqldumper.*lsass",
        "reg\\s+save.*\\\\sam\\b",
        "reg\\s+save.*\\\\system\\b",
        "reg\\s+save.*\\\\security\\b",
        "pwdump",
        "fgdump",
        "gsecdump",
        "ntdsutil",
        "vssadmin.*shadow",
        "esentutl.*ntds",
        "secretsdump",
        "DCSync",
        "hashdump",
        "lazagne",
        "pypykatz",
        "rubeus",
        "wce\\.exe",
        "crackmapexec",
        "DonPAPI",
        "masky",
        "certipy",
        "Get-GPPPassword",
        "Invoke-Kerberoast"
    ],

    "recon_patterns": [
        {"label": "net_user",       "pattern": "\\bnet\\s+user\\b"},
        {"label": "net_group",      "pattern": "\\bnet\\s+group\\b"},
        {"label": "net_localgroup", "pattern": "\\bnet\\s+localgroup\\b"},
        {"label": "whoami",         "pattern": "\\bwhoami\\b"},
        {"label": "net_accounts",   "pattern": "\\bnet\\s+accounts\\b"},
        {"label": "ipconfig",       "pattern": "\\bipconfig\\s+/all\\b"},
        {"label": "netstat",        "pattern": "\\bnetstat\\s+-an"},
        {"label": "arp",            "pattern": "\\barp\\s+-a\\b"},
        {"label": "route_print",    "pattern": "\\broute\\s+print\\b"},
        {"label": "nbtstat",        "pattern": "\\bnbtstat\\b"},
        {"label": "nslookup",       "pattern": "\\bnslookup\\b"},
        {"label": "net_view",       "pattern": "\\bnet\\s+view\\b"},
        {"label": "net_share",      "pattern": "\\bnet\\s+share\\b"},
        {"label": "net_time",       "pattern": "\\bnet\\s+time\\b"},
        {"label": "systeminfo",     "pattern": "\\bsysteminfo\\b"},
        {"label": "tasklist",       "pattern": "\\btasklist\\b"},
        {"label": "qprocess",       "pattern": "\\bqprocess\\b"},
        {"label": "query_session",  "pattern": "\\bquery\\s+(user|session)\\b"},
        {"label": "sc_query",       "pattern": "\\bsc\\s+query\\b"},
        {"label": "schtasks_query", "pattern": "\\bschtasks\\s+/query\\b"},
        {"label": "reg_query",      "pattern": "\\breg\\s+query\\b"},
        {"label": "wmic_enum",      "pattern": "\\bwmic\\s+\\w+\\s+(get|list)\\b"},
        {"label": "nltest",         "pattern": "\\bnltest\\b"},
        {"label": "dsquery",        "pattern": "\\bdsquery\\b"},
        {"label": "cmdkey",         "pattern": "\\bcmdkey\\s+/list\\b"},
        {"label": "wevtutil",       "pattern": "\\bwevtutil\\b"}
    ],

    "remote_exec_parents": {
        "wmiapsrv.exe":    "WMI",
        "wmiprvse.exe":    "WMI",
        "services.exe":    "PSEXEC-style",
        "wsmprovhost.exe": "WinRM",
        "winrshost.exe":   "WinRS",
        "dllhost.exe":     "DCOM",
        "mmc.exe":         "DCOM/MMC",
        "sshd.exe":        "SSH"
    },

    "remote_exec_children": [
        "cmd.exe",
        "powershell.exe",
        "pwsh.exe",
        "wscript.exe",
        "cscript.exe",
        "mshta.exe"
    ]
}
